%% docs/FLOWS.mmd
flowchart TD
    subgraph Ansible_Role_Execution [Ansible Role Execution Flow]
        direction TB
        RE1["tasks/main.yml"] --> RE2{"Detect OS Family"}
        RE2 -->|Alpine| RE3["tasks/Alpine.yml"]
        RE2 -->|Debian| RE4["tasks/Debian.yml"]
        RE2 -->|NixOS| RE5["tasks/NixOS.yml"]
        RE3 --> RE6["tasks/supervisord.yml"]
        RE4 --> RE6
        RE5 --> RE6
        RE6 -.->|notify| RE7["handlers/main.yml (supervisorctl restart/present)"]
    end

    subgraph CI_Pipeline [CI Pipeline Matrix]
        direction TB
        CI1["Trigger (push/PR)"] --> CI2["Run Linters (pre-commit)"]
        CI2 --> CI3["Run Molecule Matrix"]
        subgraph Molecule_Matrix [Molecule Matrix]
            direction LR
            CI4["alpine-latest"]
            CI5["debian-latest"]
            CI6["nixos-latest"]
            CI7["ubuntu-jammy"]
            CI8["ubuntu-noble"]
            CI9["ubuntu-latest"]
        end
        CI3 --> Molecule_Matrix
    end

    subgraph Molecule_Testing_Flow [Molecule Testing Sequence]
        direction TB
        M1["dependency"] --> M2["destroy"]
        M2 --> M3["syntax"]
        M3 --> M4["create"]
        M4 --> M5["prepare"]
        M5 --> M6["converge"]
        M6 --> M7["idempotence"]
        M7 --> M8["verify"]
        M8 --> M9["destroy"]
    end
