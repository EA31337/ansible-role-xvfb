%% FLOWS.mmd
flowchart TD
    subgraph Ansible_Role_Execution [Ansible Role Execution Flow]
        direction TB
        RE1["tasks/main.yml"] --> RE2{"Detect OS Family"}
        RE2 -->|Alpine| RE3["tasks/Alpine.yml"]
        RE2 -->|Debian| RE4["tasks/Debian.yml"]
        RE2 -->|NixOS| RE5["tasks/NixOS.yml"]
        RE3 --> RE6["tasks/supervisord.yml"]
        RE4 --> RE6
        RE5 --> RE6
        RE6 --> RE7["handlers/main.yml (supervisorctl restart/present)"]
    end

    subgraph CI_Pipeline [CI Pipeline Matrix]
        direction TB
        CI1["Trigger (push/PR)"] --> CI2{"Run Linters?"}
        CI2 -->|Yes| CI3["pre-commit run -a"]
        CI2 -->|No| CI4{"Run Molecule?"}
        CI4 --> CI5["Matrix: Alpine"]
        CI4 --> CI6["Matrix: Debian"]
        CI4 --> CI7["Matrix: NixOS"]
        CI4 --> CI8["Matrix: Ubuntu (jammy, noble, latest)"]
        CI5 --> CI9["Build Image & Test"]
        CI6 --> CI9
        CI7 --> CI9
        CI8 --> CI9
    end

    subgraph Molecule_Testing_Flow [Molecule Testing Sequence]
        direction TB
        M1["dependency"] --> M2["cleanup"]
        M2 --> M3["destroy"]
        M3 --> M4["syntax"]
        M4 --> M5["create"]
        M5 --> M6["prepare"]
        M6 --> M7["converge"]
        M7 --> M8["idempotence"]
        M8 --> M9["side_effect"]
        M9 --> M10["verify"]
        M10 --> M11["cleanup"]
        M11 --> M12["destroy"]
    end
